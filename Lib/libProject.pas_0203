  if AValue and (RIGHT<>'5') then
  begin
    MsgDlg('시스템관리자만 삭제가 가능합니다.', '', mtWarning);
    Result := False;
    exit;
  end;
  Result := MsgDlg('삭제하시겠습니까?', '', mtConfirmation) = IDYES;
end;

