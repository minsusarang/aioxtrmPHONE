procedure TCustomProject.LogStart(AFileName: String);
var
  fp: Integer;
begin
  FLogFileName := AFileName;

  fp := FileCreate(FLogFileName);
//  if fp < 0 then
//    DebugLevel :=0;

  FileClose(fp);
end;

procedure TCustomProject.LogStop;
begin
//
end;

function TCustomProject.Log(Msg: String; AFileName: String=''): Boolean;
var
  F : TextFile;
begin
  Result := False;

  try
    if AFileName = '' then AssignFile(F, FLogFileName)
    else  AssignFile(F, AFileName);
    Append(F);
    Writeln(F, Msg);
    CloseFile(F);
  except
    ;
  end;

  result := True;
end;

procedure TCustomProject.ShowOnTaskBar(AHandle: THandle; Value: Boolean);
begin
  case Value of
    False:
    begin
      ShowWindow(AHandle, SW_HIDE);
//      SetWindowLong(AHandle, GWL_EXSTYLE, GetWindowLong(AHandle, GWL_EXSTYLE) or WS_EX_TOOLWINDOW and not WS_EX_APPWINDOW);
      SetWindowLong(AHandle, GWL_EXSTYLE, GetWindowLong(AHandle, GWL_EXSTYLE) or WS_EX_TOOLWINDOW);
      ShowWindow(AHandle, SW_SHOW);
    end;
    True:
    begin
      ShowWindow(AHandle, SW_HIDE);
//      SetWindowLong(AHandle, GWL_EXSTYLE, GetWindowLong(AHandle, GWL_EXSTYLE) or WS_EX_TOOLWINDOW and not WS_EX_APPWINDOW);
      SetWindowLong(AHandle, GWL_EXSTYLE, GetWindowLong(AHandle, GWL_EXSTYLE) and not WS_EX_TOOLWINDOW);
      ShowWindow(AHandle, SW_SHOW);
    end;
  end;
end;

