function TCustomProject.MsgBox(const Text: PChar; Flags: Integer): Integer;
begin
  Result := Application.MessageBox(Text, PChar(FMSG_CAPTION), Flags);
end;

procedure TCustomProject.MsgBox(const Msg, Caption: String; DlgType: TMsgDlgType);
var
  Cap: String;
  Flags: Integer;
begin
  case DlgType of
    mtWarning:      Flags := MB_Ok + MB_IconWarning;
    mtError:        Flags := MB_Ok + MB_IconError;
    mtInformation:  Flags := MB_Ok + MB_IconInformation;
    mtConfirmation: Flags := MB_YesNo + mb_IconQuestion;
    mtCustom:       Flags := MB_Ok;
    else Flags := MB_Ok;
  end;

  if Caption = '' then
    Cap := FMSG_CAPTION
  else
    Cap := Caption;

  //Application.MessageBox(PChar(Msg), PChar(Cap), Flags);
  ShowMessage(Msg);
end;

function TCustomProject.MsgDlg(const Msg, Caption: String; DlgType: TMsgDlgType): Integer;
var
  Cap: String;
  Flags: Integer;
begin
  case DlgType of
    mtWarning:      Flags := MB_Ok + MB_IconWarning;
    mtError:        Flags := MB_Ok + MB_IconError;
    mtInformation:  Flags := MB_Ok + MB_IconInformation;
    mtConfirmation: Flags := MB_YesNo + mb_IconQuestion;
    mtCustom:       Flags := MB_Ok;
  end;

  if Caption = '' then
    Cap := FMSG_CAPTION
  else
    Cap := Caption;

  Result := Application.MessageBox(PChar(Msg), PChar(Cap), Flags);
end;

function TCustomProject.MsgDisplay(Msg: String; Flag: Integer): Integer;
Const
  MsgStr_Arr: array[1..4] of String = ('Error', 'Question', 'Warning', 'Information');
begin
  while Pos('|', Msg) > 0 do Msg[Pos('|', Msg)] := #13;

  Result := Application.MessageBox(PChar(Msg),PChar(MsgStr_Arr[(Flag div 10)]),StrToInt('$'+IntToStr(Flag)));
end;

procedure TCustomProject.MsgProcess(const Msg: String);
begin
  MsgDlg(Msg, '', mtInformation);
end;

